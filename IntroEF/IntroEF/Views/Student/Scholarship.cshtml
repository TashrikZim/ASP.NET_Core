
@{
    ViewData["Title"] = "Scholarship";
}

<h1>Scholarship</h1>

<table class="table table-bordered ">
    <tr>
        <th>ID</th>
        <th>Name</th>
        <th>Address</th>
        <th>CGPA</th>
    </tr>

    @foreach(var ss in Model)
    {
        <tr>
            <td>@ss.Id</td>
            <td>@ss.Name</td>
            <td>@ss.Address</td>
            <td>@ss.Cgpa</td>
        </tr>
    }



</table>

