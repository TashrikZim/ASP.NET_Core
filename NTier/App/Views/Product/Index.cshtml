@model IEnumerable<BLL.DTOs.ProductDTO>

@{
    ViewData["Title"] = "Product List";
}

<h1>Product List</h1>

<p>
    <a href="/Product/Create">Create New Product</a>
</p>

<table border="1" cellpadding="10" cellspacing="0" width="100%">
    <thead>
        <tr>
            <th>Id</th>
            <th>Name</th>
            <th>Price</th>
            <th>Quantity</th>
            <th>Category Id</th>
            <th>Actions</th>
        </tr>
    </thead>

    <tbody>
        @foreach (var item in Model)
        {
            <tr>
                <td>@item.Id</td>
                <td>@item.Name</td>
                <td>@item.Price</td>
                <td>@item.Quantity</td>
                <td>@item.Cid</td>

                <td>
                    <a href="/Product/Edit/@item.Id">Edit</a> |
                    <a href="/Product/Details/@item.Id">Details</a> |
                    <a href="/Product/Delete/@item.Id">Delete</a>
                </td>
            </tr>
        }
    </tbody>
</table>